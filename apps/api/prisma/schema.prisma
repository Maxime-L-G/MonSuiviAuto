generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  PROFESSIONAL
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)

  vehicles     Vehicle[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum VehicleUsage {
  PERSONAL
  PROFESSIONAL
}

model Vehicle {
  id        String       @id @default(cuid())
  userId    String
  make      String
  model     String
  year      Int
  currentKm Int
  usage      VehicleUsage @default(PERSONAL)
  archivedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maintenances Maintenance[]
  reminders    Reminder[]
  documents    Document[]

  @@index([userId])
}

model Document {
  id           String   @id @default(cuid())
  vehicleId    String
  filename     String
  url          String
  originalName String
  mimeType     String
  sizeBytes    Int

  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([vehicleId])
}

enum MaintenanceType {
  OIL_CHANGE
  TIRES
  BRAKES
  BATTERY
  INSPECTION
  REPAIR
  OTHER
}

model Maintenance {
  id        String          @id @default(cuid())
  vehicleId String
  type      MaintenanceType @default(OTHER)
  title     String
  date      DateTime
  mileage   Int
  costCents Int             @default(0)
  notes     String?         @db.Text

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
}

enum ReminderType {
  INSPECTION
  INSURANCE
  OIL_CHANGE
  CUSTOM
}

enum ReminderStatus {
  OPEN
  DONE
}

model Reminder {
  id          String         @id @default(cuid())
  vehicleId   String
  type        ReminderType   @default(CUSTOM)
  title       String
  status      ReminderStatus @default(OPEN)

  dueDate     DateTime?
  dueMileage  Int?

  notes       String?        @db.Text
  emailSentAt DateTime?

  vehicle     Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([vehicleId])
  @@index([status])
}
